# Chrome Web Store credentials
# Setup: https://developer.chrome.com/docs/webstore/using-api
#   1. Create OAuth client at https://console.cloud.google.com/apis/credentials (Desktop app)
#   2. Enable Chrome Web Store API at https://console.cloud.google.com/apis/library/chromewebstore.googleapis.com
#   3. Run: npx chrome-webstore-upload-keys (enter client ID + secret → get refresh token)
#   4. Find extension ID at https://chrome.google.com/webstore/devconsole
CWS_EXTENSION_ID=
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=

# Firefox Add-ons (AMO) credentials
# Get these at: https://addons.mozilla.org/en-US/developers/addon/api/key/
AMO_JWT_ISSUER=
AMO_JWT_SECRET=
AMO_CHANNEL=listed
