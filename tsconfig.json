{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "noEmitOnError": true,
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "noUncheckedIndexedAccess": false,
    "types": ["chrome", "node"],
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": [
    "packages/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["server/**", "dist/**", "dist-firefox/**", "dist-relay/**", "node_modules/**"]
}
