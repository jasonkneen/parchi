{
  "manifest_version": 3,
  "name": "Parchi",
  "browser_specific_settings": {
    "gecko": {
      "id": "{01750513-9c5b-418a-af8e-31344dd293e3}",
      "strict_min_version": "112.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "version": "0.4.60",
  "description": "Warm-paper browser automation assistant with configurable LLM/vision profiles and enterprise-ready controls",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "identity",
    "storage",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.convex.cloud/*",
    "https://*.convex.site/*"
  ],
  "action": {
    "default_title": "Parchi Panel"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "sidebar_action": {
    "default_panel": "sidepanel/panel.html",
    "default_title": "Parchi Panel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
